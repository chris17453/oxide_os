# Modules/Setup.local for OXIDE OS
# Static builtins needed for a minimal Python REPL

*static*
# Core modules needed for REPL
_struct _struct.c
binascii binascii.c
math mathmodule.c
cmath cmathmodule.c
_random _randommodule.c
_bisect _bisectmodule.c
_heapq _heapqmodule.c
_json _json.c
_csv _csv.c
_datetime _datetimemodule.c
_opcode _opcode.c
_statistics _statisticsmodule.c
array arraymodule.c
_contextvars _contextvarsmodule.c
_queue _queuemodule.c

# Hashing - use builtin implementations
_md5 md5module.c -I$(srcdir)/Modules/_hacl/include _hacl/Hacl_Hash_MD5.c -D_BSD_SOURCE -D_DEFAULT_SOURCE
_sha1 sha1module.c -I$(srcdir)/Modules/_hacl/include _hacl/Hacl_Hash_SHA1.c -D_BSD_SOURCE -D_DEFAULT_SOURCE
_sha2 sha2module.c -I$(srcdir)/Modules/_hacl/include Modules/_hacl/libHacl_Hash_SHA2.a
_sha3 sha3module.c -I$(srcdir)/Modules/_hacl/include _hacl/Hacl_Hash_SHA3.c -D_BSD_SOURCE -D_DEFAULT_SOURCE
_blake2 _blake2/blake2module.c _blake2/blake2b_impl.c _blake2/blake2s_impl.c

# Unicode data (needed for str operations)
unicodedata unicodedata.c

# Text encodings
_codecs_cn cjkcodecs/_codecs_cn.c
_codecs_hk cjkcodecs/_codecs_hk.c
_codecs_iso2022 cjkcodecs/_codecs_iso2022.c
_codecs_jp cjkcodecs/_codecs_jp.c
_codecs_kr cjkcodecs/_codecs_kr.c
_codecs_tw cjkcodecs/_codecs_tw.c
_multibytecodec cjkcodecs/multibytecodec.c

# POSIX subset
fcntl fcntlmodule.c
grp grpmodule.c
termios termios.c
syslog syslogmodule.c

# select with poll only
select selectmodule.c

# Readline (provided by libc)
readline readline.c

*disabled*
# Things we definitely can't support
_lsprof
_testclinic
_asyncio
audioop
_bz2
_crypt
_ctypes
_curses
_curses_panel
_dbm
_decimal
_gdbm
_lzma
_multiprocessing
_posixsubprocess
_posixshmem
_socket
_ssl
_hashlib
_tkinter
_uuid
_xxsubinterpreters
_xxinterpchannels
_xxtestfuzz
_testbuffer
_testinternalcapi
_testcapi
_testimportmultiple
_testmultiphase
_testsinglephase
_ctypes_test
mmap
nis
ossaudiodev
pyexpat
_elementtree
resource
spwd
xx
xxlimited
xxlimited_35
xxsubtype
_pickle
_zoneinfo
zlib
