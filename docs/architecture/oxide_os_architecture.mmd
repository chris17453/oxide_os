flowchart LR
    subgraph Host["Host Build + Tooling"]
        Toolchain["toolchain/: oxide-cc/ld toolchains"]
        Scripts["scripts/, mk/, Makefile automation"]
        PkgMgr["pkgmgr/: oxdnf builder"]
        Build["build/, target/, targets/: artifacts"]
    end
    Toolchain --> Build
    Scripts --> Build
    PkgMgr --> Build

    subgraph Boot["Boot Path"]
        Firmware["UEFI firmware"]
        BootUEFI["bootloader/boot-uefi"]
        BootInfo["boot_proto::BootInfo + mem map"]
    end
    Build --> BootUEFI
    Firmware --> BootUEFI
    BootUEFI --> BootInfo

    subgraph Kernel["Kernel (kernel/)"]
        KernelMain["kernel/src/init.rs::kernel_main"]
        subgraph Arch["Architecture + platform"]
            ArchX86["arch-x86_64"]
            ArchAarch["arch-aarch64 stub"]
            ArchMips["arch-mips64 stub"]
            ACPI["acpi/ firmware tables"]
            SMP["smp/ + smp_init.rs"]
        end
        subgraph Memory["Memory management"]
            MMCore["mm-core/mm-manager"]
            Paging["mm-paging"]
            Heap["mm-heap + mm-slab"]
            COW["mm-cow"]
        end
        subgraph ProcSched["Tasks & syscalls"]
            Scheduler["sched/"]
            Process["proc/ + exec/ + signal/"]
            Syscall["syscall/ boundary"]
            IPC["tty/pty + async glue"]
        end
        subgraph Storage["Storage + filesystems"]
            BlockLayer["block/block + gpt"]
            MediaAuto["media/automount"]
            VFS["vfs/ mount glue"]
            Ext4["fs/ext4"]
            FAT32["fs/fat32"]
            OxideFS["fs/oxidefs"]
            Tmpfs["tmpfs"]
            Procfs["procfs"]
            Devfs["devfs"]
        end
        subgraph Networking["Networking stack"]
            TCPIP["net/tcpip"]
            DHCP["net/dhcp"]
            DNS["net/dns"]
            SMB["net/smb"]
            NFS["net/nfs"]
            RDP["net/rdp"]
        end
        subgraph SecurityContainer["Security + containerization"]
            Crypto["security/{crypto,x509,trust}"]
            Quarantine["security/quarantine"]
            Namespaces["container/namespace"]
            Cgroups["container/cgroup"]
            Seccomp["container/seccomp"]
        end
        subgraph Hypervisor["hypervisor/"]
            VMX["vmx"]
            VMM["vmm"]
            VirtioEmu["virtio-emu"]
        end
        subgraph IO["Display/input/audio/USB/perf/AI"]
            Framebuffer["graphics/fb"]
            Terminal["tty/terminal + vt"]
            PTY["tty/pty + pts dir"]
            InputCore["input/"]
            AudioCore["audio/"]
            USBStack["usb/"]
            PerfMon["perf/"]
            AI["ai/{embed,hnsw,indexd}"]
        end
        subgraph Drivers["drivers/* + module/"]
            DriverFramework["driver-traits + module loader"]
            subgraph BlockDrv["Block drivers"]
                VirtIOBlk["virtio-blk"]
                NVMe["nvme"]
                AHCI["ahci"]
            end
            subgraph NetDrv["Network drivers"]
                VirtIONet["virtio-net"]
            end
            subgraph GPUD["GPU driver"]
                VirtIOGPU["virtio-gpu"]
            end
            subgraph AudioDrv["Audio drivers"]
                IntelHDA["intel-hda"]
                VirtIOSnd["virtio-snd"]
            end
            subgraph InputDrv["Input drivers"]
                PS2["ps2"]
                VirtIOInput["virtio-input"]
            end
            subgraph USBDrv["USB drivers"]
                XHCI["xhci host"]
                USBHID["usb-hid"]
                USBMSC["usb-msc"]
            end
            Serial["serial/uart-8250"]
        end
    end

