# config.site override for cross compiling CPython to OXIDE OS
#
# Based on Tools/wasm/config.site-wasm32-wasi with OXIDE-specific settings.

# Cannot be detected in cross builds
ac_cv_buggy_getaddrinfo=no

# No /dev/pt*
ac_cv_file__dev_ptmx=no
ac_cv_file__dev_ptc=no

# No resource limits
ac_cv_header_sys_resource_h=no

# No eventfd
ac_cv_func_eventfd=no

# We have pipe
ac_cv_func_pipe=yes

# No fifos/special files
ac_cv_func_mkfifo=no
ac_cv_func_mkfifoat=no
ac_cv_func_mknod=no
ac_cv_func_mknodat=no
ac_cv_func_makedev=no

# No fdopendir
ac_cv_func_fdopendir=no

# No AF_UNIX or AF_PACKET
ac_cv_header_sys_un_h=no
ac_cv_header_netpacket_packet_h=no

# No accept
ac_cv_func_accept=no
ac_cv_func_accept4=no

# No vectored I/O
ac_cv_func_preadv=no
ac_cv_func_readv=no
ac_cv_func_pwritev=no
ac_cv_func_writev=no
ac_cv_func_preadv2=no
ac_cv_func_pwritev2=no

# No fork/exec (yet) - stub for now
ac_cv_func_fork=no
ac_cv_func_fork1=no
ac_cv_func_vfork=no
ac_cv_func_execv=no
ac_cv_func_posix_spawn=no
ac_cv_func_posix_spawnp=no

# No shared libraries / dlopen - but provide header with RTLD constants
ac_cv_func_dlopen=no
ac_cv_func_dlsym=no
ac_cv_func_dlclose=no
ac_cv_header_dlfcn_h=yes

# Threads - we have pthread support
ac_cv_pthread=yes
ac_cv_func_pthread_init=yes
ac_cv_header_pthread_h=yes
ac_cv_defined__POSIX_THREADS_unistd_h=yes

# Enable langinfo - now properly implemented in libc
ac_cv_func_nl_langinfo=yes
ac_cv_header_langinfo_h=yes

# No terminal stuff
ac_cv_func_openpty=no

# Enable zlib - stub implementation in libc with CRC32 support
ac_cv_header_zlib_h=yes
ac_cv_lib_z_gzread=no
ac_cv_have_z=yes
ac_cv_func_forkpty=no
ac_cv_header_pty_h=no
ac_cv_header_utmp_h=no
ac_cv_header_util_h=no

# No networking headers beyond basics
ac_cv_header_netdb_h=no
ac_cv_header_arpa_inet_h=no
ac_cv_header_netinet_in_h=no
ac_cv_header_netinet_tcp_h=no

# sys/select - stub implementation with fd_set macros
ac_cv_header_sys_select_h=yes
ac_cv_func_select=no

# No advanced process features
ac_cv_func_setsid=yes
ac_cv_func_setpgid=yes
ac_cv_func_getpgid=yes
ac_cv_func_setgroups=no
ac_cv_func_initgroups=no
ac_cv_func_getgroups=no
ac_cv_func_sched_setaffinity=no
ac_cv_func_sched_setscheduler=no

# Functions we DO have
ac_cv_func_read=yes
ac_cv_func_write=yes
ac_cv_func_close=yes
ac_cv_func_open=yes
ac_cv_func_lseek=yes
ac_cv_func_dup=yes
ac_cv_func_dup2=yes
ac_cv_func_getcwd=yes
ac_cv_func_chdir=yes
ac_cv_func_mkdir=yes
ac_cv_func_rmdir=yes
ac_cv_func_unlink=yes
ac_cv_func_rename=yes
ac_cv_func_stat=yes
ac_cv_func_fstat=yes
ac_cv_func_lstat=yes
ac_cv_func_isatty=yes
ac_cv_func_getpid=yes
ac_cv_func_getppid=yes
ac_cv_func_getuid=yes
ac_cv_func_geteuid=yes
ac_cv_func_getgid=yes
ac_cv_func_getegid=yes
ac_cv_func_nanosleep=yes
ac_cv_func_clock_gettime=yes
ac_cv_func_gettimeofday=yes
ac_cv_func_time=yes
ac_cv_func_sleep=yes
ac_cv_func_usleep=yes
ac_cv_func_mmap=yes
ac_cv_func_munmap=yes
ac_cv_func_mprotect=yes

# Functions we DON'T have
ac_cv_func_alarm=no
ac_cv_func_pause=no
ac_cv_func_sigaction=no
ac_cv_func_siginterrupt=no
ac_cv_func_sigpending=no
ac_cv_func_sigprocmask=no
ac_cv_func_sigrelse=no
ac_cv_func_sigwait=no
ac_cv_func_sigwaitinfo=no
ac_cv_func_sigtimedwait=no
ac_cv_func_getitimer=no
ac_cv_func_setitimer=no
ac_cv_func_getloadavg=no
ac_cv_func_getlogin=no
ac_cv_func_getpass=no
ac_cv_func_getpriority=no
ac_cv_func_setpriority=no
ac_cv_func_sendfile=no
ac_cv_func_statvfs=no
ac_cv_func_fstatvfs=no
ac_cv_func_lchown=no
ac_cv_func_chown=no
ac_cv_func_chmod=no
ac_cv_func_fchmod=no
ac_cv_func_fchown=no
ac_cv_func_link=no
ac_cv_func_symlink=no
ac_cv_func_readlink=no
ac_cv_func_realpath=no
ac_cv_func_truncate=no
ac_cv_func_ftruncate=yes
ac_cv_func_utimes=no
ac_cv_func_futimes=no
ac_cv_func_lutimes=no
ac_cv_func_umask=no
ac_cv_func_access=no
ac_cv_func_faccessat=no
ac_cv_func_fchmodat=no
ac_cv_func_fchownat=no
ac_cv_func_linkat=no
ac_cv_func_mkdirat=no
ac_cv_func_openat=no
ac_cv_func_renameat=no
ac_cv_func_symlinkat=no
ac_cv_func_unlinkat=no
ac_cv_func_readlinkat=no
ac_cv_func_utimensat=no
ac_cv_func_futimens=no
ac_cv_func_copy_file_range=no
ac_cv_func_splice=no
ac_cv_func_tee=no
ac_cv_func_poll=no
ac_cv_func_epoll_create=no
ac_cv_func_epoll_create1=no
ac_cv_func_kqueue=no
ac_cv_func_sem_open=no
ac_cv_func_sem_timedwait=no
ac_cv_func_sem_getvalue=no
ac_cv_func_sem_unlink=no
ac_cv_func_shm_open=no
ac_cv_func_shm_unlink=no
ac_cv_func_madvise=no
ac_cv_func_getentropy=no
ac_cv_func_getrandom=yes
ac_cv_func_times=no
ac_cv_func_explicit_bzero=no
ac_cv_func_explicit_memset=no
ac_cv_func_posix_fallocate=no
ac_cv_func_posix_fadvise=no
ac_cv_func_pread=no
ac_cv_func_pwrite=no
ac_cv_func_fdatasync=no
ac_cv_func_fsync=no
ac_cv_func_sync=no
ac_cv_func_getrusage=no
ac_cv_func_wait3=no
ac_cv_func_wait4=no
ac_cv_func_waitid=no
ac_cv_func_system=no
ac_cv_func_confstr=no
ac_cv_func_sysconf=no
ac_cv_func_fpathconf=no
ac_cv_func_pathconf=no
ac_cv_func_ctermid=no
ac_cv_func_tcgetpgrp=yes
ac_cv_func_tcsetpgrp=yes
ac_cv_func_ttyname=no
ac_cv_func_socketpair=no
ac_cv_func_getpeername=no
ac_cv_func_getsockname=no
ac_cv_func_gethostname=no
ac_cv_func_sethostname=no
ac_cv_func_getaddrinfo=no
ac_cv_func_getnameinfo=no
ac_cv_func_inet_aton=no
ac_cv_func_inet_pton=no

# Sizes for cross compilation
ac_cv_sizeof_int=4
ac_cv_sizeof_long=8
ac_cv_sizeof_long_long=8
ac_cv_sizeof_void_p=8
ac_cv_sizeof_short=2
ac_cv_sizeof_float=4
ac_cv_sizeof_double=8
ac_cv_sizeof_fpos_t=8
ac_cv_sizeof_size_t=8
ac_cv_sizeof_pid_t=4
ac_cv_sizeof_uintptr_t=8
ac_cv_sizeof_off_t=8
ac_cv_sizeof_time_t=8
ac_cv_sizeof_wchar_t=4
ac_cv_sizeof__Bool=1

# Type alignments
ac_cv_alignof_int=4
ac_cv_alignof_long=8
ac_cv_alignof_long_long=8
ac_cv_alignof_void_p=8
ac_cv_alignof_short=2
ac_cv_alignof_float=4
ac_cv_alignof_double=8
ac_cv_alignof_size_t=8
ac_cv_alignof_max_align_t=16

# Byte order
ac_cv_c_bigendian=no

# Working features
ac_cv_type_ssize_t=yes
ac_cv_type_pid_t=yes
ac_cv_type_uid_t=yes
ac_cv_type_gid_t=yes
ac_cv_type_mode_t=yes
ac_cv_type_off_t=yes

# Headers we have
ac_cv_header_stdlib_h=yes
ac_cv_header_string_h=yes
ac_cv_header_strings_h=no
ac_cv_header_stdio_h=yes
ac_cv_header_stdint_h=yes
ac_cv_header_stdbool_h=yes
ac_cv_header_stdarg_h=yes
ac_cv_header_stddef_h=yes
ac_cv_header_errno_h=yes
ac_cv_header_limits_h=yes
ac_cv_header_float_h=yes
ac_cv_header_math_h=yes
ac_cv_header_ctype_h=yes
ac_cv_header_signal_h=yes
ac_cv_header_time_h=yes
ac_cv_header_unistd_h=yes
ac_cv_header_fcntl_h=yes
ac_cv_header_setjmp_h=yes
ac_cv_header_dirent_h=yes
ac_cv_header_locale_h=yes
ac_cv_header_wchar_h=yes
ac_cv_header_wctype_h=yes
ac_cv_header_inttypes_h=yes
ac_cv_header_assert_h=yes
ac_cv_header_sys_stat_h=yes
ac_cv_header_sys_types_h=yes
ac_cv_header_sys_time_h=yes
ac_cv_header_sys_mman_h=yes
ac_cv_header_sys_wait_h=yes
ac_cv_header_sys_ioctl_h=yes
ac_cv_header_sys_utsname_h=yes
ac_cv_header_pwd_h=yes
ac_cv_header_grp_h=yes

# Headers we have for random
ac_cv_header_sys_random_h=yes

# Locale support - disable nl_langinfo
ac_cv_func_nl_langinfo=no
ac_cv_header_langinfo_h=no

# Headers we DON'T have
ac_cv_header_spawn_h=no
ac_cv_header_sys_socket_h=no
ac_cv_header_sys_statvfs_h=no
ac_cv_header_sys_param_h=no
ac_cv_header_sys_file_h=no
ac_cv_header_sys_lock_h=no
# ac_cv_header_sys_random_h set above to yes
ac_cv_header_sys_sendfile_h=no
ac_cv_header_sys_epoll_h=no
ac_cv_header_sys_event_h=no
ac_cv_header_sys_sem_h=no
ac_cv_header_sys_shm_h=no
ac_cv_header_sys_msg_h=no
ac_cv_header_sys_ipc_h=no
ac_cv_header_sys_uio_h=no
ac_cv_header_sys_termios_h=no
ac_cv_header_sys_times_h=yes
ac_cv_header_termios_h=yes
ac_cv_header_poll_h=no
ac_cv_header_linux_can_h=no
ac_cv_header_linux_random_h=no
ac_cv_header_linux_tipc_h=no
ac_cv_header_linux_vm_sockets_h=no
ac_cv_header_sysexits_h=no
ac_cv_header_syslog_h=yes
ac_cv_header_conio_h=no
ac_cv_header_direct_h=no
ac_cv_header_io_h=no
ac_cv_header_process_h=no
ac_cv_header_libintl_h=no
ac_cv_header_langinfo_h=no
ac_cv_header_sys_kern_control_h=no
ac_cv_header_sys_loadavg_h=no
ac_cv_header_sys_mkdev_h=no
ac_cv_header_sys_modem_h=no
ac_cv_header_sys_sysmacros_h=no
ac_cv_header_term_h=no
ac_cv_header_curses_h=no
ac_cv_header_ncurses_h=no

# No computed gotos detection in cross compile
ac_cv_computed_gotos=yes

# Printf long double
ac_cv_opt_olimit_ok=no

# Working snprintf
ac_cv_func_snprintf=yes
ac_cv_func_vsnprintf=yes

# No shared library support
ac_cv_lib_dl_dlopen=no

# Math - we have libm functions in our libc
ac_cv_lib_m_acos=yes
ac_cv_func_acosh=yes
ac_cv_func_asinh=yes
ac_cv_func_atanh=yes
ac_cv_func_copysign=yes
ac_cv_func_erf=yes
ac_cv_func_erfc=yes
ac_cv_func_expm1=yes
ac_cv_func_finite=yes
ac_cv_func_hypot=yes
ac_cv_func_isinf=yes
ac_cv_func_isnan=yes
ac_cv_func_lgamma=yes
ac_cv_func_log1p=yes
ac_cv_func_log2=yes
ac_cv_func_round=yes
ac_cv_func_tgamma=yes

# Disable int-conversion
ac_cv_disable_int_conversion=yes

# memfd_create not available
ac_cv_func_memfd_create=no

# No crypt
ac_cv_func_crypt=no
ac_cv_func_crypt_r=no

# strlcpy/strlcat
ac_cv_func_strlcpy=yes
ac_cv_func_strlcat=yes
