# config.site override for cross compiling CPython to OXIDE OS
#
# Based on Tools/wasm/config.site-wasm32-wasi with OXIDE-specific settings.

# Cannot be detected in cross builds
ac_cv_buggy_getaddrinfo=no

# PTY device nodes
ac_cv_file__dev_ptmx=yes
ac_cv_file__dev_ptc=no

# Resource limits
ac_cv_header_sys_resource_h=yes

# We have eventfd stub
ac_cv_func_eventfd=no

# We have pipe
ac_cv_func_pipe=yes

# mkfifo/mknod - stubs return ENOSYS
ac_cv_func_mkfifo=no
ac_cv_func_mkfifoat=no
ac_cv_func_mknod=no
ac_cv_func_mknodat=no
ac_cv_func_makedev=yes

# fdopendir
ac_cv_func_fdopendir=yes

# AF_UNIX and AF_PACKET
ac_cv_header_sys_un_h=yes
ac_cv_header_netpacket_packet_h=yes

# Socket functions
ac_cv_func_accept=yes
ac_cv_func_accept4=yes

# Vectored I/O - fully implemented
ac_cv_func_preadv=yes
ac_cv_func_readv=yes
ac_cv_func_pwritev=yes
ac_cv_func_writev=yes
ac_cv_func_preadv2=yes
ac_cv_func_pwritev2=yes

# Fork/exec - fully implemented
ac_cv_func_fork=yes
ac_cv_func_fork1=no
ac_cv_func_vfork=yes
ac_cv_func_execv=yes
ac_cv_func_posix_spawn=yes
